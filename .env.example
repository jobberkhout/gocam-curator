# LLM provider: "anthropic" or "gemini"
LLM_PROVIDER=anthropic

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_key_here

# Model versions — change to use a different/cheaper/less-loaded model version.
# Defaults shown below; uncomment and edit to override.
# ANTHROPIC_MODEL=claude-sonnet-4-5
# GEMINI_MODEL=gemini-2.5-pro

# Inter-call delay to avoid rate limits. API_CALL_DELAY sets both providers;
# provider-specific vars override it. Defaults: Anthropic=2s, Gemini=10s.
# API_CALL_DELAY=5           # override both providers at once
# ANTHROPIC_API_CALL_DELAY=2
# GEMINI_API_CALL_DELAY=10
